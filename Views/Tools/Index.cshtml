        <h5 class="mb-3">📋 Cómo Integrar IA en CoreWhatIf</h5>
        
        <div class="accordion" id="aiIntegration">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#aiStep1">
                        <strong>Paso 1:</strong> &nbsp; Obtener API Key
                    </button>
                </h2>
                <div id="aiStep1" class="accordion-collapse collapse show" data-bs-parent="#aiIntegration">
                    <div class="accordion-body">
                        <p><strong>OpenAI:</strong></p>
                        <ol>
                            <li>Crea cuenta en <a href="https://platform.openai.com/signup" target="_blank">platform.openai.com</a></li>
                            <li>Ve a "API Keys" en tu perfil</li>
                            <li>Click en "Create new secret key"</li>
                            <li>Copia y guarda la clave (solo se muestra una vez)</li>
                            <li>Añade créditos en "Billing" para empezar a usar</li>
                        </ol>
                        <p><strong>Anthropic (Claude):</strong></p>
                        <ol>
                            <li>Crea cuenta en <a href="https://console.anthropic.com/" target="_blank">console.anthropic.com</a></li>
                            <li>Ve a "API Keys"</li>
                            <li>Genera una nueva clave</li>
                            <li>Configura límites de gasto</li>
                        </ol>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#aiStep2">
                        <strong>Paso 2:</strong> &nbsp; Configurar en appsettings.json
                    </button>
                </h2>
                <div id="aiStep2" class="accordion-collapse collapse" data-bs-parent="#aiIntegration">
                    <div class="accordion-body">
                        <p>Añade la configuración de IA en tu <code>appsettings.json</code>:</p>
                        <pre class="bg-light p-3 rounded"><code>{
  "AI": {
    "OpenAI": {
      "ApiKey": "sk-...",
      "Model": "gpt-4-turbo-preview",
      "MaxTokens": 2000,
      "Temperature": 0.7
    },
    "Anthropic": {
      "ApiKey": "sk-ant-...",
      "Model": "claude-3-opus-20240229",
      "MaxTokens": 4000
    },
    "Google": {
      "ApiKey": "AIza...",
      "Model": "gemini-pro"
    }
  }
}</code></pre>
                        <div class="alert alert-warning mt-3">
                            <strong>⚠️ Seguridad:</strong> Nunca subas las API Keys a Git. Usa variables de entorno o Azure Key Vault en producción.
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#aiStep3">
                        <strong>Paso 3:</strong> &nbsp; Instalar Paquetes NuGet
                    </button>
                </h2>
                <div id="aiStep3" class="accordion-collapse collapse" data-bs-parent="#aiIntegration">
                    <div class="accordion-body">
                        <p>Instala los paquetes necesarios:</p>
                        <pre class="bg-light p-3 rounded"><code># OpenAI
dotnet add package OpenAI

# Anthropic (Claude)
dotnet add package Anthropic.SDK

# Google Gemini
dotnet add package Google.Cloud.AIPlatform.V1

# Azure OpenAI
dotnet add package Azure.AI.OpenAI</code></pre>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#aiStep4">
                        <strong>Paso 4:</strong> &nbsp; Crear Servicio de IA
                    </button>
                </h2>
                <div id="aiStep4" class="accordion-collapse collapse" data-bs-parent="#aiIntegration">
                    <div class="accordion-body">
                        <p>Ejemplo de servicio para OpenAI:</p>
                        <pre class="bg-light p-3 rounded"><code>public class OpenAIService
{
    private readonly OpenAIClient _client;
    private readonly string _model;

    public OpenAIService(IConfiguration config)
    {
        var apiKey = config["AI:OpenAI:ApiKey"];
        _model = config["AI:OpenAI:Model"];
        _client = new OpenAIClient(apiKey);
    }

    public async Task&lt;string&gt; ChatAsync(string prompt)
    {
        var response = await _client.GetChatCompletionsAsync(
            new ChatCompletionsOptions
            {
                Messages = {
                    new ChatMessage(ChatRole.System, "Eres un asistente útil."),
                    new ChatMessage(ChatRole.User, prompt)
                },
                Model = _model,
                MaxTokens = 2000
            }
        );
        
        return response.Value.Choices[0].Message.Content;
    }
}</code></pre>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#aiStep5">
                        <strong>Paso 5:</strong> &nbsp; Usar en tu Controlador
                    </button>
                </h2>
                <div id="aiStep5" class="accordion-collapse collapse" data-bs-parent="#aiIntegration">
                    <div class="accordion-body">
                        <pre class="bg-light p-3 rounded"><code>public class ChatController : Controller
{
    private readonly OpenAIService _aiService;

    public ChatController(OpenAIService aiService)
    {
        _aiService = aiService;
    }

    [HttpPost]
    public async Task&lt;IActionResult&gt; SendMessage(string message)
    {
        var response = await _aiService.ChatAsync(message);
        return Json(new { response });
    }
}</code></pre>
                    </div>
                </div>
            </div>
        </div>

