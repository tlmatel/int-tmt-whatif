                + '<td class="text-end">' + fmt(c.arrActual) + ' €</td>'
                + '<td class="text-end text-muted"><s>' + fmt(c.listArr) + ' €</s></td>'
                + '<td class="text-center">' + pctInput + '</td>'
                + '<td class="text-end text-success fw-bold">' + fmt(c.finalArr) + ' €</td>'
                + '<td class="text-end text-danger">' + (c.discount > 0 ? '-' + fmt(c.discount) + ' €' : '—') + '</td>'
                + '<td class="text-end">' + fmt(c.infraCost) + ' € ' + infraBadge + '</td>'
                + '<td class="text-end ' + argClass + ' fw-bold">' + argIcon + ' ' + fmt(Math.abs(c.argument)) + ' €</td>'
                + '<td class="text-end ' + (c.sobrecoste >= 0 ? 'text-success' : 'text-danger') + '">' + (c.sobrecoste >= 0 ? '+' : '') + fmt(c.sobrecoste) + ' €</td>'
                + '<td class="text-center"><input type="number" class="form-control form-control-sm text-center client-inc ' + (c.hasCustomInc ? 'border-warning' : '') + '" style="width:55px;padding:1px 3px" data-code="' + c.code + '" value="' + Math.round(c.deltaArrPct) + '" min="-50" max="500" step="5"> <small class="text-muted">' + (c.effectiveInc > 0 && Math.round(c.deltaArrPct) < c.effectiveInc ? '⚠' : '') + '</small></td>'
                + '<td>' + satBadges + '</td>'
                + '</tr>';
        });
        document.getElementById('client-table').innerHTML = html;

        // Bind per-client discount inputs
        document.querySelectorAll('.client-pct').forEach(function(input) {
            input.addEventListener('change', function() {
                var code = parseInt(this.dataset.code);
                var val = parseInt(this.value);
                var globalPct = parseInt(document.getElementById('rate-margin').value);
                if (isNaN(val) || val === globalPct) {
                    delete clientDiscounts[code];
                } else {
                    clientDiscounts[code] = Math.max(0, Math.min(70, val));
                }
                calculate();
            });
        });

        // Bind per-client increment inputs
        document.querySelectorAll('.client-inc').forEach(function(input) {
            input.addEventListener('change', function() {
                var code = parseInt(this.dataset.code);
                var val = parseInt(this.value);
                var globalInc = parseInt(document.getElementById('rate-increment').value);
                if (isNaN(val) || val === globalInc) {
                    delete clientIncrements[code];
                } else {
                    clientIncrements[code] = Math.max(-50, Math.min(500, val));
                }
                calculate();
            });
        });

        // Bind per-client exclude checkboxes
        document.querySelectorAll('.client-chk').forEach(function(chk) {
            chk.addEventListener('change', function() {
                var code = parseInt(this.dataset.code);
                if (this.checked) {
                    delete excludedClients[code];
                } else {
                    excludedClients[code] = true;
                }
                calculate();
            });
        });

        // Bind click for modal bridge
        document.querySelectorAll('.client-row').forEach(function(row) {
            row.addEventListener('click', function(e) {
                if (e.target.tagName === 'INPUT') return;
                renderClientBridge(this.dataset);
                var modal = new bootstrap.Modal(document.getElementById('bridgeModal'));
                modal.show();
            });
        });
    }

    var clientBridgeChart;

    // Plugin: connector lines between bars
    var waterfallLinesPlugin = {
        id: 'waterfallLines',
        afterDatasetsDraw: function(chart) {
            var meta = chart.getDatasetMeta(0);
            var ctx = chart.ctx;
            ctx.save();
            ctx.strokeStyle = '#333';
            ctx.lineWidth = 1.5;
            ctx.setLineDash([4, 3]);
            for (var i = 0; i < meta.data.length - 1; i++) {
                var curr = meta.data[i];
                var next = meta.data[i + 1];
                var currTop = Math.min(curr.y, curr.base);
                var nextTop = Math.min(next.y, next.base);
                var currBottom = Math.max(curr.y, curr.base);
                var yLine = curr.y < curr.base ? curr.y : curr.base;
                ctx.beginPath();
                ctx.moveTo(curr.x + curr.width / 2, yLine);
                ctx.lineTo(next.x - next.width / 2, yLine);
                ctx.stroke();
            }
            ctx.restore();
        }
    };

    // Plugin: data labels on bars
    var dataLabelsPlugin = {
        id: 'waterfallLabels',
        afterDatasetsDraw: function(chart) {
            var meta = chart.getDatasetMeta(0);
            var ctx = chart.ctx;
            ctx.save();
            ctx.font = 'bold 11px sans-serif';
            ctx.textAlign = 'center';
            var rawValues = chart.data.datasets[0]._rawValues;
            if (!rawValues) return;
            for (var i = 0; i < meta.data.length; i++) {
                var bar = meta.data[i];
                var val = rawValues[i];
                var yPos = Math.min(bar.y, bar.base) - 8;
                ctx.fillStyle = '#333';
                var label = (val >= 0 && i > 0 && i < meta.data.length - 1 ? '+' : '') + fmt(Math.round(val)) + ' €';
                ctx.fillText(label, bar.x, yPos);
            }
            ctx.restore();
        }
    };

    function renderClientBridge(d) {
        var arrActual = parseFloat(d.arractual);
        var infraCost = parseFloat(d.infracost);
        var listArr = parseFloat(d.listarr);
        var discount = parseFloat(d.discount);
        var finalArr = parseFloat(d.finalarr);
        var argument = parseFloat(d.argument);
        var pct = d.pct;
        var name = d.name;
        var code = d.code;
        var infraReal = d.infrareal === 'true';

        var totalAntes = arrActual + infraCost;
        var sobrecoste = finalArr - arrActual;

        var ahorroCliente = totalAntes - finalArr;
        var incrementalArr = finalArr - arrActual;

        var labels = ['ARR actual', 'Hardware\nactual', 'New ARR', 'Descuento', '− Hardware\nactual', 'ARR final', 'AHORRO\ncliente', 'INCREMENTAL\nARR'];

        var barData = [];
        var colors = [];

        // Bar 0: ARR actual (starts at 0)
        barData.push([0, arrActual]);
        colors.push('#5B9BD5');

        // Bar 1: Hardware (stacks on top)
        barData.push([arrActual, arrActual + infraCost]);
        colors.push('#5B9BD5');

        // Bar 2: New ARR = precio lista (desde 0)
        barData.push([0, listArr]);
        colors.push('#5B9BD5');

        // Bar 3: Descuento (goes down)
        barData.push([listArr - discount, listArr]);
        colors.push('#FF4444');

        // Bar 4: -Hardware (goes down)
        var afterDiscount = listArr - discount;
        barData.push([afterDiscount - infraCost, afterDiscount]);
        colors.push('#FF4444');

        // Bar 5: ARR final (from 0)
        barData.push([0, finalArr]);
        colors.push('#5B9BD5');

        // Bar 6: Ahorro cliente = (ARR actual + HW) - ARR final
        barData.push([0, Math.abs(ahorroCliente)]);
        colors.push(ahorroCliente >= 0 ? '#70AD47' : '#FF4444');

        // Bar 7: Incremental ARR = ARR final - ARR actual (lo que ganamos nosotros)
        barData.push([0, Math.abs(incrementalArr)]);
        colors.push(incrementalArr >= 0 ? '#FFC000' : '#FF4444');

        var rawValues = [arrActual, infraCost, listArr, -discount, -infraCost, finalArr, ahorroCliente, incrementalArr];

        if (clientBridgeChart) clientBridgeChart.destroy();
        clientBridgeChart = new Chart(document.getElementById('chart-client-bridge'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: barData,
                    backgroundColor: colors,
                    borderColor: '#3a6fa5',
                    borderWidth: 1,
                    _rawValues: rawValues
                }]
            },
            plugins: [waterfallLinesPlugin, dataLabelsPlugin],
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    title: { display: true, text: 'Bridge ARR — ' + name, font: { size: 14 } },
                    tooltip: { callbacks: { label: function(ctx) { var v = rawValues[ctx.dataIndex]; return (v >= 0 ? '+' : '') + fmt(Math.round(v)) + ' €'; } } }
                },
                scales: {
                    x: { ticks: { font: { size: 10 } } },
                    y: { title: { display: true, text: '€' }, ticks: { callback: function(v) { return fmt(v); } } }
                }
            }
        });

        // Claim text
        var infraLabel = infraReal ? '' : ' <span class="badge bg-warning text-dark">estimado</span>';
        var resultClass = argument >= 0 ? 'text-success' : 'text-danger';
        var resultIcon = argument >= 0 ? '✓' : '✗';
        var ahorroNeto = totalAntes - finalArr;

        var claimHtml = '<h5 class="mb-3"><code>' + code + '</code> ' + name + '</h5>'
            + '<div class="row mb-3"><div class="col-md-6">'
            + '<table class="table table-sm table-borderless mb-0">'
            + '<tr class="border-bottom"><td colspan="2"><strong>HOY PAGA</strong></td></tr>'
            + '<tr><td>Mantenimiento OnPremise:</td><td class="text-end">' + fmt(arrActual) + ' €</td></tr>'
            + '<tr><td>Infraestructura HW:' + infraLabel + '</td><td class="text-end">' + fmt(infraCost) + ' €</td></tr>'
            + '<tr class="fw-bold border-top bg-light"><td>TOTAL HOY:</td><td class="text-end">' + fmt(totalAntes) + ' €/año</td></tr>'
            + '</table></div><div class="col-md-6">'
            + '<table class="table table-sm table-borderless mb-0">'
            + '<tr class="border-bottom"><td colspan="2"><strong>CON CORE SAAS</strong></td></tr>'
            + '<tr><td>Precio lista:</td><td class="text-end">' + fmt(listArr) + ' €</td></tr>'
            + (discount > 0 ? '<tr class="text-success"><td>Descuento ' + pct + '%:</td><td class="text-end">−' + fmt(discount) + ' €</td></tr>' : '')
            + '<tr><td>Infraestructura:</td><td class="text-end">0 € (incluida)</td></tr>'
            + '<tr class="fw-bold border-top bg-light"><td>TOTAL NUEVO:</td><td class="text-end text-primary">' + fmt(finalArr) + ' €/año</td></tr>'
            + '</table></div></div>'
            + '<div class="p-3 rounded border ' + (ahorroNeto >= 0 ? 'border-success bg-success bg-opacity-10' : 'border-danger bg-danger bg-opacity-10') + '">'
            + '<div class="row text-center">'
            + '<div class="col-md-4"><small class="text-muted">Total hoy (ARR+HW)</small><br><strong class="fs-5">' + fmt(totalAntes) + ' €</strong></div>'
            + '<div class="col-md-1 d-flex align-items-center justify-content-center"><strong class="fs-4">−</strong></div>'
            + '<div class="col-md-4"><small class="text-muted">Nuevo ARR Core</small><br><strong class="fs-5 text-primary">' + fmt(finalArr) + ' €</strong></div>'
            + '<div class="col-md-1 d-flex align-items-center justify-content-center"><strong class="fs-4">=</strong></div>'
            + '<div class="col-md-2"><small class="text-muted">Ahorro</small><br><strong class="fs-4 ' + resultClass + '">' + (ahorroNeto >= 0 ? '+' : '') + fmt(ahorroNeto) + ' €</strong></div>'
            + '</div></div>'
            + '<p class="mt-3 mb-0 fst-italic border-start border-3 border-primary ps-3">«Hoy pagas <strong>' + fmt(totalAntes) + '€/año</strong> entre mantenimiento e infra. '
            + 'Con Core SaaS te cobraríamos ' + fmt(listArr) + '€'
            + (discount > 0 ? ', pero te hacemos un <strong>' + pct + '% de descuento</strong> → pagas <strong>' + fmt(finalArr) + '€</strong>' : '')
            + '. Ya no pagas infraestructura. '
            + (ahorroNeto >= 0 ? '<strong class="text-success">Te ahorras ' + fmt(ahorroNeto) + '€/año</strong>.' : 'Inviertes ' + fmt(Math.abs(ahorroNeto)) + '€/año más, pero sin HW y con producto cloud moderno.') + '»</p>';

        document.getElementById('bridge-claim').innerHTML = claimHtml;
    }

    // Sort icons update
    function updateSortIcons() {
        document.querySelectorAll('th.sortable .sort-icon').forEach(function(icon) {
            var th = icon.closest('th');
            if (th.dataset.col === sortCol) {
                icon.className = sortDir === 'asc' ? 'bi bi-sort-up sort-icon' : 'bi bi-sort-down sort-icon';
            } else {
                icon.className = 'bi bi-arrow-down-up sort-icon opacity-50';
            }
        });
    }

    // Sort click handlers
    document.querySelectorAll('th.sortable').forEach(function(th) {
        th.style.cursor = 'pointer';
        th.addEventListener('click', function() {
            var col = this.dataset.col;
            if (sortCol === col) {
                sortDir = sortDir === 'asc' ? 'desc' : 'asc';
            } else {
                sortCol = col;
                sortDir = (col === 'name' || col === 'partner' || col === 'code') ? 'asc' : 'desc';
            }
            renderTable(lastClientRows);
        });
    });

    // Clear filters
    document.getElementById('btn-clear-filters').addEventListener('click', function() {
        document.getElementById('filter-search').value = '';
        document.getElementById('filter-partner').value = '';
        document.getElementById('filter-sat').value = '';
        document.getElementById('filter-usr-min').value = '';
        document.getElementById('filter-usr-max').value = '';
        document.getElementById('filter-arr-min').value = '';
        document.getElementById('filter-arr-max').value = '';
        renderTable(lastClientRows);
    });

    // Events
    document.getElementById('chk-all').addEventListener('change', function() {
        var checked = this.checked;
        if (checked) {
            excludedClients = {};
        } else {
            DB.clients.forEach(function(c) { excludedClients[c.code] = true; });
        }
        calculate();
    });
    document.querySelectorAll('.tier-input').forEach(function(el) { el.addEventListener('change', calculate); });
    document.getElementById('rate-infra').addEventListener('input', calculate);
    document.getElementById('rate-margin').addEventListener('input', function() {
        if (parseInt(this.value) > 0) {
            document.getElementById('rate-increment').value = 0;
        }
        calculate();
    });
    document.getElementById('rate-increment').addEventListener('input', function() {
        if (parseInt(this.value) > 0) {
            document.getElementById('rate-margin').value = 0;
        }
        calculate();
    });
    document.querySelectorAll('.sat-slider').forEach(function(el) { el.addEventListener('input', calculate); });
    document.getElementById('filter-search').addEventListener('input', function() { renderTable(lastClientRows); });
    document.getElementById('filter-partner').addEventListener('change', function() { renderTable(lastClientRows); });
    document.getElementById('filter-sat').addEventListener('change', function() { renderTable(lastClientRows); });
    document.getElementById('filter-usr-min').addEventListener('input', function() { renderTable(lastClientRows); });
    document.getElementById('filter-usr-max').addEventListener('input', function() { renderTable(lastClientRows); });
    document.getElementById('filter-arr-min').addEventListener('input', function() { renderTable(lastClientRows); });
    document.getElementById('filter-arr-max').addEventListener('input', function() { renderTable(lastClientRows); });

    calculate();
})();
</script>
}
