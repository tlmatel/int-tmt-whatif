<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoreWhatIf</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoreWhatIf.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"
                   title="@(User.FindFirst("hubrd_debug")?.Value ?? "No auth data")">CoreWhatIf</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="WhatIf" asp-action="Dashboard">
                                <i class="bi bi-graph-up"></i> Core What If
                            </a>
                        </li>
                        @if (User.IsInRole("admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="WhatIf" asp-action="Simulador">
                                    <i class="bi bi-calculator"></i> Simulador
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="WhatIf" asp-action="PlanMigracion">
                                    <i class="bi bi-rocket-takeoff"></i> Plan Migración
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="WhatIf" asp-action="ComparadorPlanes">
                                    <i class="bi bi-bar-chart-line"></i> Comparador
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @(User.Claims.FirstOrDefault(c => c.Type == "name")?.Value
                                      ?? User.Identity.Name ?? "Usuario")
                                    @if (User.IsInRole("admin"))
                                    {
                                        <span class="badge bg-danger ms-1">Admin</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        @if (User.Identity?.IsAuthenticated == true && ViewContext.HttpContext.Request.Query.ContainsKey("debug"))
        {
            <div class="alert alert-secondary mt-3" style="font-size: 0.8rem;">
                <strong><i class="bi bi-bug"></i> DEBUG Claims:</strong>
                <br/>IsInRole("admin"): <strong>@User.IsInRole("admin")</strong>
                &nbsp;|&nbsp; IsInRole("user"): <strong>@User.IsInRole("user")</strong>
                &nbsp;|&nbsp; IsInRole("gestor"): <strong>@User.IsInRole("gestor")</strong>
                <hr/>
                <ul class="mb-0">
                    @foreach (var claim in User.Claims)
                    {
                        <li><strong>@claim.Type</strong>: @claim.Value</li>
                    }
                </ul>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CoreWhatIf - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
