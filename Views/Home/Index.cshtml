@{
    ViewData["Title"] = "CoreWhatIf - Esqueleto Base";
}

<div class="text-center my-5">
    <h1 class="display-5 fw-bold" style="color: #2c3e50;">Plataforma Base <span style="color: #3498db;">para Aplicaciones</span></h1>
    <h2 class="display-5 fw-bold" style="color: #2c3e50;">Empresariales <span style="color: #3498db;">en .NET</span></h2>
    <p class="lead text-muted mt-3">Todo lo que necesitas para lanzar tu sistema profesional listo para producción.</p>
    
    <div class="mt-4">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="DummyRecords" asp-action="Index" class="btn btn-primary btn-lg me-2 px-4">
                🚀 Ver Demo
            </a>
        }
        else
        {
            <a asp-controller="DummyRecords" asp-action="Index" class="btn btn-primary btn-lg me-2 px-4">
                🚀 Ver Demo
            </a>
        }
        <a href="#stack" class="btn btn-outline-secondary btn-lg px-4">
            💻 Ver Stack Tecnológico
        </a>
    </div>
</div>

<div class="row mb-5" id="stack">
    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow border-primary" style="border-width: 2px;">
            <div class="card-body p-4">
                <h5 class="card-title mb-4">
                    <span class="text-primary">⚙️</span> <strong>Stack Tecnológico</strong>
                </h5>
                <ul class="list-unstyled">
                    <li class="mb-2">✓ <strong>ASP.NET Core MVC</strong> (.NET 10 LTS)</li>
                    <li class="mb-2">✓ <strong>PostgreSQL</strong> + EF Core</li>
                    <li class="mb-2">✓ <strong>ASP.NET Identity</strong></li>
                    <li class="mb-2">✓ <strong>Bootstrap 5</strong> + Razor</li>
                    <li class="mb-2">✓ <strong>Migraciones automáticas</strong></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow border-success" style="border-width: 2px;">
            <div class="card-body p-4">
                <h5 class="card-title mb-4">
                    <span class="text-success">✨</span> <strong>Características Incluidas</strong>
                </h5>
                <ul class="list-unstyled">
                    <li class="mb-2">✓ <strong>Sistema de usuarios completo</strong></li>
                    <li class="mb-2">✓ <strong>Autorización y roles</strong></li>
                    <li class="mb-2">✓ <strong>CRUD de ejemplo</strong></li>
                    <li class="mb-2">✓ <strong>Seed inicial configurable</strong></li>
                    <li class="mb-2">✓ <strong>Configuración por entornos</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="text-center mb-5">
    <h3 class="fw-bold mb-4" style="color: #2c3e50;">Capacidades de la Plataforma</h3>
</div>

