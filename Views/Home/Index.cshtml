                            <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0"/>
                        </svg>
                    </div>
                </div>
                <h5 class="fw-bold mb-3">Seguridad Empresarial</h5>
                <p class="text-muted">Autenticación, roles, sesiones seguras y protección CSRF.</p>
            </div>
        </div>
    </div>
</div>

