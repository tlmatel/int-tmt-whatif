@{
    ViewData["Title"] = "Error de Autenticación";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 50vh">
    <div class="text-center" style="max-width:500px">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size:3rem"></i>
        <h2 class="mt-3">Error de Autenticación</h2>
        <p class="text-muted">@ViewBag.ErrorMessage</p>
        <div class="d-flex gap-2 justify-content-center mt-4">
            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/" class="btn btn-primary">
                <i class="bi bi-arrow-clockwise me-1"></i> Reintentar
            </a>
            <a asp-controller="Account" asp-action="Welcome" class="btn btn-outline-secondary">
                <i class="bi bi-house me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
