@{
    ViewData["Title"] = "Bienvenido";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh">
    <div class="text-center" style="max-width:480px">
        <div class="rounded-3 bg-primary d-inline-flex align-items-center justify-content-center mb-4" style="width:90px;height:90px">
            <i class="bi bi-graph-up-arrow text-white" style="font-size:2.8rem"></i>
        </div>
        <h1 class="display-6 fw-bold mb-2">Core What If</h1>
        <p class="text-muted mb-4">
            Migration Pricing Analyzer<br>
            <small>Inicia sesión para acceder al simulador, planes de migración y comparador.</small>
        </p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar Sesión
        </a>
        <p class="text-muted mt-4 small">
            Autenticación gestionada por Auth0
        </p>
    </div>
</div>
